  "db_name": "PostgreSQL",
  "query": "\n            SELECT u.id, u.email, u.display_name,\n                u.role AS \"role: Role\",\n                u.is_active, u.created_at, u.updated_at\n            FROM oauth_credentials oc\n            JOIN users u ON u.id = oc.user_id\n            WHERE oc.provider = $1 AND oc.provider_user_id = $2\n            ",
